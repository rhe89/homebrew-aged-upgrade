#!/usr/bin/env bash
# brew tap rhe/aged-upgrade
# brew tap 
# brew aged-upgrade
#
# Oppgraderer pakker (formulae og/eller casks) til den nyeste versjonen der
# formula-/cask-filen er eldre enn N dager. Hvis siste versjon er for fersk,
# brukes siste eldre git-revisjon av formula-/cask-filen.
#
# Avhenger av:
#   - git
#   - jq
#
# Eksempler:
#   brew aged-upgrade                   # default 7 dager, både formula + cask
#   brew aged-upgrade --days 14         # 14 dager
#   brew aged-upgrade --formula         # kun formula
#   brew aged-upgrade --cask            # kun casks
#   brew aged-upgrade --days 3 --cask   # kun casks eldre enn 3 dager

set -euo pipefail

DAYS=7
ONLY_FORMULA=0
ONLY_CASK=0

usage() {
  cat <<EOF
Usage: brew aged-upgrade [options]

Options:
  --days N        Minimum alder i dager på versjonen som installeres (default: 7)
  --formula       Bare formulae
  --cask          Bare casks
  -h, --help      Vis denne hjelpen

Eksempler:
  brew aged-upgrade
  brew aged-upgrade --days 14
  brew aged-upgrade --formula
  brew aged-upgrade --days 3 --cask
EOF
}

brew tap homebrew/cask --force
brew tap homebrew/core --force

while [[ $# -gt 0 ]]; do
  case "$1" in
    --days)
      shift
      if [[ $# -eq 0 ]]; then
        echo "Error: --days trenger en verdi" >&2
        exit 1
      fi
      DAYS="$1"
      ;;
    --formula)
      ONLY_FORMULA=1
      ;;
    --cask)
      ONLY_CASK=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Ukjent flagg: $1" >&2
      usage
      exit 1
      ;;
  esac
  shift
done

if ! command -v jq >/dev/null 2>&1; then
  echo "Error: jq er påkrevd. Installer med: brew install jq" >&2
  exit 1
fi

if ! command -v git >/dev/null 2>&1; then
  echo "Error: git er påkrevd." >&2
  exit 1
fi

if ! [[ "$DAYS" =~ ^[0-9]+$ ]]; then
  echo "Error: --days må være heltall, fikk: $DAYS" >&2
  exit 1
fi

NOW_TS=$(date +%s)
CUTOFF_TS=$(( NOW_TS - DAYS * 86400 ))

echo "brew aged-upgrade: oppgraderer til nyeste pakkeversjon som er eldre enn $DAYS dager."
echo "Cutoff timestamp: $CUTOFF_TS"
echo

# global liste over kandidater som skal oppgraderes
declare -a upgrade_list=()
declare -a restore_list=()

restore_checked_out_files() {
  local entry repo_root ruby_rel

  for entry in "${restore_list[@]}"; do
    repo_root="${entry%%|*}"
    ruby_rel="${entry#*|}"

    if [[ -d "$repo_root" ]]; then
      git -C "$repo_root" checkout -- "$ruby_rel" >/dev/null 2>&1 || true
    fi
  done
}

trap restore_checked_out_files EXIT

gather_outdated() {
  local type="$1" # "formula" eller "cask"
  local outdated

  if [[ "$type" == "formula" ]]; then
    outdated=$(brew outdated --formula --quiet || true)
  else
    outdated=$(brew outdated --cask --quiet || true)
  fi

  if [[ -z "$outdated" ]]; then
    echo "Ingen utdaterte $type."
    echo
    return
  fi

  echo "Utdaterte $type:"
  echo "$outdated"
  echo

  while read -r pkg; do
    [[ -z "$pkg" ]] && continue

    echo "Analyserer $type: $pkg"

    # Hent info via brew info --json=v2
    local info_json
    if [[ "$type" == "formula" ]]; then
      # formulae: toppnivå er et objekt med nøkkelen "formulae"
      info_json=$(brew info --formula --json=v2 "$pkg" 2>/dev/null | jq '.formulae[0]')
    else
      # casks: toppnivå er et objekt med nøkkelen "casks"
      info_json=$(brew info --cask --json=v2 "$pkg" 2>/dev/null | jq '.casks[0]')
    fi

    if [[ -z "$info_json" || "$info_json" == "null" ]]; then
      echo "  Fant ikke info for $pkg, hopper over."
      echo
      continue
    fi

    # For både formula og cask bruker vi tap + ruby_source_path
    local tap ruby_rel
    tap=$(echo "$info_json" | jq -r '.tap // empty')
    ruby_rel=$(echo "$info_json" | jq -r '.ruby_source_path // empty')

    if [[ -z "$tap" || -z "$ruby_rel" || "$ruby_rel" == "null" ]]; then
      echo "  Fant ikke tap/ruby_source_path for $pkg, hopper over."
      echo
      continue
    fi

    # Finn repo-root for tap
    local repo_root
    repo_root=$(brew --repo "$tap" 2>/dev/null || true)

    echo "repo_root: $repo_root"
    # brew --repo $repo_root
    
    if [[ -z "$repo_root" || ! -d "$repo_root" ]]; then
      echo "  Fant ikke repo-root for tap $tap, hopper over."
      echo
      continue
    fi

    local path
    path="$repo_root/$ruby_rel"

    if [[ ! -f "$path" ]]; then
      echo "  Fant ikke filen $path for $pkg, hopper over."
      echo
      continue
    fi

    # Siste commit-tid (unix timestamp) for akkurat denne filen
    local commit_ts latest_commit
    commit_ts=$(git -C "$repo_root" log -1 --format=%ct -- "$path" 2>/dev/null || true)
    latest_commit=$(git -C "$repo_root" log -1 --format=%H -- "$path" 2>/dev/null || true)
    if [[ -z "$commit_ts" ]]; then
      echo "  Fant ikke commit-historikk for $path, hopper over."
      echo
      continue
    fi

    local age_sec age_days
    age_sec=$(( NOW_TS - commit_ts ))
    age_days=$(( age_sec / 86400 ))

    echo "  Siste commit TS: $commit_ts (ca. ${age_days} dager gammel)"

    local selected_commit selected_ts selected_age_sec selected_age_days needs_checkout
    selected_commit="$latest_commit"
    selected_ts="$commit_ts"
    needs_checkout=0

    if (( commit_ts <= CUTOFF_TS )); then
      echo "  -> Siste versjon kvalifiserer (eldre enn $DAYS dager)."
    else
      echo "  -> Siste versjon er for fersk, finner nyeste eldre revisjon."

      selected_commit=$(git -C "$repo_root" log -1 --before="@$CUTOFF_TS" --format=%H -- "$ruby_rel" 2>/dev/null || true)

      if [[ -z "$selected_commit" ]]; then
        echo "  Fant ingen eldre revisjon for $pkg, hopper over."
        echo
        continue
      fi

      selected_ts=$(git -C "$repo_root" show -s --format=%ct "$selected_commit" 2>/dev/null || true)
      if [[ -z "$selected_ts" ]]; then
        echo "  Fant ikke tidspunkt for eldre revisjon $selected_commit, hopper over."
        echo
        continue
      fi

      selected_age_sec=$(( NOW_TS - selected_ts ))
      selected_age_days=$(( selected_age_sec / 86400 ))
      needs_checkout=1

      echo "  -> Valgt revisjon ${selected_commit:0:12} (ca. ${selected_age_days} dager gammel)."
    fi

    upgrade_list+=("$type|$pkg|$repo_root|$ruby_rel|$selected_commit|$needs_checkout")
    echo "  -> Legger til for oppgradering."
    echo
  done <<< "$outdated"
}

# Bestem hva vi skal se på
if [[ "$ONLY_CASK" -eq 1 && "$ONLY_FORMULA" -eq 0 ]]; then
  gather_outdated "cask"
elif [[ "$ONLY_FORMULA" -eq 1 && "$ONLY_CASK" -eq 0 ]]; then
  gather_outdated "formula"
else
  gather_outdated "formula"
  echo "---------------------------"
  gather_outdated "cask"
fi

if [[ "${#upgrade_list[@]}" -eq 0 ]]; then
  echo "Ingen pakker oppfylte alderskravet ($DAYS dager)."
  exit 0
fi

echo "Følgende pakker vil oppgraderes (type:navn):"
for entry in "${upgrade_list[@]}"; do
  IFS='|' read -r type pkg repo_root ruby_rel selected_commit needs_checkout <<< "$entry"
  if [[ "$needs_checkout" -eq 1 ]]; then
    echo "  $type:$pkg @ ${selected_commit:0:12}"
  else
    echo "  $type:$pkg"
  fi
done
echo

# Kjør selve oppgraderingen
for entry in "${upgrade_list[@]}"; do
  IFS='|' read -r type pkg repo_root ruby_rel selected_commit needs_checkout <<< "$entry"

  if [[ "$needs_checkout" -eq 1 ]]; then
    if ! git -C "$repo_root" diff --quiet -- "$ruby_rel" || ! git -C "$repo_root" diff --cached --quiet -- "$ruby_rel"; then
      echo "Hopper over $type:$pkg fordi $ruby_rel har lokale endringer i $repo_root."
      continue
    fi

    echo "Bruker eldre revisjon for $type:$pkg: ${selected_commit:0:12}"
    git -C "$repo_root" checkout "$selected_commit" -- "$ruby_rel"
    restore_list+=("$repo_root|$ruby_rel")
  fi

  if [[ "$type" == "cask" ]]; then
    echo "Oppgraderer cask: $pkg"
    HOMEBREW_NO_AUTO_UPDATE=1 HOMEBREW_NO_INSTALL_FROM_API=1 brew upgrade --cask "$pkg"
  else
    echo "Oppgraderer formula: $pkg"
    HOMEBREW_NO_AUTO_UPDATE=1 HOMEBREW_NO_INSTALL_FROM_API=1 brew upgrade "$pkg"
  fi

  if [[ "$needs_checkout" -eq 1 ]]; then
    git -C "$repo_root" checkout -- "$ruby_rel"
  fi
done

echo
echo "Ferdig."
